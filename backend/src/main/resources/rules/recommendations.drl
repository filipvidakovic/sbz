package com.lol.recommender.rules;

import com.lol.recommender.model.Champion;
import com.lol.recommender.model.Fact;
import com.lol.recommender.model.Strategy;
import com.lol.recommender.model.Recommendation;

// ============================================================
//  NIVO 3: PREPORUKE
//  Strategy + Fact → konkretni champion
//  Svaki champion ima jasno definisane uslove i razloge.
//  "not Champion(team == 'ally', name == 'X')" sprečava
//  preporuku championa koji je već u timu.
// ============================================================

// ════════════════════════════════════════════════════════════
//  MALPHITE
// ════════════════════════════════════════════════════════════

rule "Recommend Malphite – perfect vs AD dive"
    salience 60
    when
        Strategy(name == "pickFrontlineEngage")
        Fact(name == "enemyMostlyAD")
        not Champion(team == "ally", name == "Malphite")
    then
        Recommendation r = new Recommendation("Malphite", 97);
        r.addReason("team critically needs both frontline AND engage");
        r.addReason("Malphite R is one of the best engage abilities in the game");
        r.addReason("passive armor scaling counters enemy AD damage");
        insert(r);
end

rule "Recommend Malphite – tank vs AD assassins"
    salience 58
    when
        Strategy(name == "pickTank")
        Fact(name == "enemyHasAssassin")
        Fact(name == "enemyMostlyAD")
        not Champion(team == "ally", name == "Malphite")
    then
        Recommendation r = new Recommendation("Malphite", 93);
        r.addReason("enemy AD assassins are countered by Malphite's armor");
        r.addReason("team needs a tank");
        insert(r);
end

rule "Recommend Malphite – engage into poke"
    salience 55
    when
        Strategy(name == "hardEngageVsPoke")
        not Champion(team == "ally", name == "Malphite")
    then
        Recommendation r = new Recommendation("Malphite", 88);
        r.addReason("unstoppable R hard counters poke-and-engage enemy compositions");
        r.addReason("can engage from long range to punish overextended pokers");
        insert(r);
end

