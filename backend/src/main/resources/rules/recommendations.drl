end

// ════════════════════════════════════════════════════════════
//  RAMMUS
// ════════════════════════════════════════════════════════════

rule "Recommend Rammus – hard counter multiple AD assassins"
    salience 62
    when
        Fact(name == "enemyHasMultipleAssassins")
        Fact(name == "enemyMostlyAD")
        not Champion(team == "ally", name == "Rammus")
    then
        Recommendation r = new Recommendation("Rammus", 96);
        r.addReason("multiple AD assassins – Rammus is a direct hard counter");
        r.addReason("Thornmail passive deals damage back to attackers");
        r.addReason("taunt forces enemies to attack the most armored champion");
        insert(r);
end

rule "Recommend Rammus – vs full AD burst"
    salience 58
    when
        Fact(name == "enemyIsFullBurst")
        Fact(name == "enemyMostlyAD")
        not Champion(team == "ally", name == "Rammus")
    then
        Recommendation r = new Recommendation("Rammus", 90);
        r.addReason("full AD burst composition is negated by extreme armor stacking");
        r.addReason("Rammus ult disrupts assassins before they can burst carries");
        insert(r);
end

